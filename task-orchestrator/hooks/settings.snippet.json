{
  "//": "Pega esto en .claude/settings.json (o fusiónalo con tus hooks existentes).",
  "//paths": "Asume la skill instalada en .claude/skills/task-orchestrator/. Ajusta si la pusiste en ~/.claude/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/skills/task-orchestrator/hooks/block-default-branch.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/skills/task-orchestrator/hooks/require-tests-before-push.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/skills/task-orchestrator/hooks/auto-format.sh" }
        ]
      }
    ]
  }
}
